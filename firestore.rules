rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // each anonymous user can only read/write their own game state
    match /diesel_states/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // each anonymous user can only read/write their own push-notification token
    match /fcmTokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // everything else is closed by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
